rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Booking inquiries - anyone can create (guests pay deposit without account)
    // Validate required fields and limit document size
    match /booking_inquiries/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'type', 'status'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 255
        && request.resource.data.type == 'booking'
        && request.resource.data.status == 'new'
        && request.resource.data.keys().size() < 40;
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid || resource.data.email == request.auth.token.email);
      allow delete: if false;
    }

    // Tour requests - anyone can create (no auth required for tour form)
    // Validate required fields
    match /tour_requests/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'status'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 255
        && request.resource.data.status == 'new'
        && request.resource.data.keys().size() < 20;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Chef bookings - authenticated users can create
    match /chef_bookings/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().size() < 20;
      allow read: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Chefs - anyone can read, only authenticated can write (admin)
    match /chefs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Team members - anyone can read, only authenticated can write (admin)
    match /team_members/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
