rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Admin allowlist ===
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'emmettg@griffithind.com',
          'bakkers4640@gmail.com'
        ];
    }

    function isOwner(resource) {
      return request.auth != null && (
        resource.data.userId == request.auth.uid
        || (resource.data.email is string && resource.data.email == request.auth.token.email)
      );
    }

    // === User profiles ===
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
      // Admin can read all profiles for support
      allow read: if isAdmin();
    }

    // === Booking inquiries — paying customers ===
    // Anyone can create (guests pay without account). Owners + admins can read/update.
    match /booking_inquiries/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'type', 'status'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 255
        && request.resource.data.type == 'booking'
        && request.resource.data.status == 'new'
        && request.resource.data.keys().size() < 50;

      allow read: if isOwner(resource) || isAdmin();
      allow update: if isOwner(resource) || isAdmin();
      allow delete: if isAdmin();
    }

    // === Tour requests ===
    // Anyone can create (no auth needed). Only the requester (by email) + admin can read.
    match /tour_requests/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'status'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0
        && request.resource.data.email.size() < 255
        && request.resource.data.status == 'new'
        && request.resource.data.keys().size() < 25;

      allow read: if isOwner(resource) || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // === Chef bookings ===
    // Authenticated users can create. Only the booking user + assigned chef + admin can read.
    match /chef_bookings/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().size() < 25;

      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.chefEmail == request.auth.token.email
        || isAdmin()
      );
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.chefEmail == request.auth.token.email
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // === Chefs — public profile data ===
    match /chefs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Team members — public profile data ===
    match /team_members/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === External bookings from Hospitable (Airbnb/VRBO/direct via Hospitable) ===
    // Only the Cloud Function can write these (service account bypasses rules).
    // Admin can read for the dashboard.
    match /external_bookings/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Cloud Functions only (admin SDK bypasses rules)
    }
  }
}
